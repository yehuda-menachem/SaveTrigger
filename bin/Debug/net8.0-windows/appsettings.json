{
  "AppSettings": {
    "MonitoredFolders": [
      "D:\\OneDrive\\לקוחות"
    ],
    "TargetMonitorIndex": 1,
    "DebounceMs": 1500,
    "MaxManagedWindows": 5,
    "FileStabilizationPollMs": 500,
    "FileStabilizationRetries": 5,
    "ActivityWindowSeconds": 10,
    "TempFileExtensions": [
      ".tmp",
      ".crdownload",
      ".part",
      ".download",
      ".partial",
      ".~tmp"
    ],
    "IgnorePrefixes": [
      "~$",
      ".~",
      "._"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  }
}